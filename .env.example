# or "gemini"
LLM_PROVIDER="openai"
GEMINI_API_KEY=
OPENAI_API_KEY=

ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true

# Local LLM fallback (Ollama). Note: root URL of the Ollama server, NO /v1 suffix.
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:70b-instruct-q4_K_M

# Auth + per-user daily quota (only OpenAI/Gemini count toward this limit)
DAILY_QUERY_LIMIT=10
USAGE_DB_PATH=./data/usage.db
AUTH_CREDENTIALS_PATH=./src/auth/credentials.yaml
